rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Dashboard Rules
    match /dashboards/{dashboardId} {
      function isValidDashboard(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.userId == request.auth.uid
          && data.widgets is list
          && (data.isPublic is bool || !data.keys().hasAll(['isPublic']));
      }

      allow read: if isSignedIn() && (isOwner(existing().userId) || existing().isPublic == true || (existing().sharedWith is list && request.auth.uid in existing().sharedWith));
      
      allow create: if isSignedIn() && isValidId(dashboardId) && isValidDashboard(incoming()) 
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn() && isValidDashboard(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          isOwner(existing().userId) || 
          (request.auth.uid in existing().sharedWith && incoming().diff(existing()).affectedKeys().hasOnly(['widgets', 'updatedAt', 'name']))
        );
        
      allow delete: if isOwner(existing().userId);
    }

    // Dataset Rules
    match /datasets/{datasetId} {
      function isValidDataset(data) {
        return data.name is string && data.name.size() > 0
          && data.userId == request.auth.uid
          && data.data is list
          && data.columns is list;
      }

      allow read: if isSignedIn() && isOwner(existing().userId);
      
      allow create: if isSignedIn() && isValidId(datasetId) && isValidDataset(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if false; // Datasets are immutable for now
      
      allow delete: if isOwner(existing().userId);
    }

    // Analysis Rules
    match /analyses/{analysisId} {
      function isValidAnalysis(data) {
        return data.datasetId is string && data.report is string;
      }

      allow read: if isSignedIn(); // Broad read if they have the ID, usually linked from dataset
      
      allow create: if isSignedIn() && isValidAnalysis(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if false;
      
      allow delete: if isSignedIn(); 
    }
  }
}
